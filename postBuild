#!/bin/bash

# Generate DESCRIPTION file
cat > DESCRIPTION <<EOL
Package: osf_3kem6
Type: Package
Title: Repo2Docker Project
Version: 1.0
Authors@R: c(person("Maintainer", "Example", email = "maintainer@example.com", role = c("aut", "cre")))
Description: Automatically generated DESCRIPTION file for Repo2Docker.
License: MIT
Imports:
    qgraph,
EOL

# Remove trailing comma in DESCRIPTION file
sed -i '$ s/,$//' DESCRIPTION

# Install FlowR
R -e "remotes::install_github('flowr-analysis/rstudio-addin-flowr')"

# Install additional R packages
R -e "if (!requireNamespace('qgraph', quietly = TRUE)) install.packages('qgraph', repos = 'http://cran.us.r-project.org')"
